class Solution {
    public int getSecondLargest(int[] arr) {
        int max=0;
      for(int i=0;i<arr.length;i++){
          if(max<arr[i]){
              max=arr[i];
          }
      }
      int secmax=-1;
      for(int i=0;i<arr.length;i++){
          if(arr[i]>secmax&&arr[i]!=max){
              secmax=arr[i];
          }
      }
      return secmax;
    }
}
